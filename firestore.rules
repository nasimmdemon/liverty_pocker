rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Game rooms for multiplayer
    match /games/{gameId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    // Referral codes: public read (so invitees see who invited them), write only by referrer
    match /referralCodes/{code} {
      allow read: if true;
      allow create, update: if request.auth != null && request.resource.data.referrerId == request.auth.uid;
      allow delete: if false;
    }
    // Referrals: create when new user signs up (referredId must match auth), read by referrer
    match /referrals/{refId} {
      allow create: if request.auth != null && request.resource.data.referredId == request.auth.uid;
      allow read, update: if request.auth != null;
    }
  }
}
